{
  "name": "@found-in-space/skykit",
  "version": "0.1.1",
  "description": "Reusable runtime for building Found in Space sky experiences",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/Found-in-Space/skykit.git"
  },
  "homepage": "https://github.com/Found-in-Space/skykit#readme",
  "bugs": {
    "url": "https://github.com/Found-in-Space/skykit/issues"
  },
  "exports": {
    ".": "./src/index.js",
    "./coords": "./src/coords/index.js",
    "./loading": "./src/loading/index.js",
    "./movement": "./src/movement/index.js",
    "./presets": "./src/presets/index.js",
    "./query": "./src/query/index.js",
    "./render2d": "./src/render2d/index.js",
    "./render3d": "./src/render3d/index.js"
  },
  "files": [
    "src",
    "!src/demo",
    "!src/demo/**",
    "!src/**/__tests__",
    "!src/**/__tests__/**",
    "!src/**/*.test.js",
    "!src/**/*.test.mjs",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "diag:observer-shell": "node ./scripts/observer-shell-diagnostic.js",
    "lookup:bookmark-star": "node ./scripts/bookmark-star-lookup.js",
    "test": "node --test",
    "test:watch": "node --test --watch"
  },
  "dependencies": {
    "three": "^0.170.0"
  },
  "devDependencies": {
    "vite": "^6.0.0"
  }
}
