{
  "name": "@found-in-space/skykit",
  "version": "0.1.1",
  "description": "Reusable runtime for building Found in Space sky experiences",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/Found-in-Space/skykit.git"
  },
  "homepage": "https://github.com/Found-in-Space/skykit#readme",
  "bugs": {
    "url": "https://github.com/Found-in-Space/skykit/issues"
  },
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    },
    "./coords": {
      "types": "./src/coords/index.d.ts",
      "default": "./src/coords/index.js"
    },
    "./loading": {
      "types": "./src/loading/index.d.ts",
      "default": "./src/loading/index.js"
    },
    "./movement": {
      "types": "./src/movement/index.d.ts",
      "default": "./src/movement/index.js"
    },
    "./presets": {
      "types": "./src/presets/index.d.ts",
      "default": "./src/presets/index.js"
    },
    "./query": {
      "types": "./src/query/index.d.ts",
      "default": "./src/query/index.js"
    },
    "./render2d": {
      "types": "./src/render2d/index.d.ts",
      "default": "./src/render2d/index.js"
    },
    "./render3d": {
      "types": "./src/render3d/index.d.ts",
      "default": "./src/render3d/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "coords": [
        "src/coords/index.d.ts"
      ],
      "loading": [
        "src/loading/index.d.ts"
      ],
      "movement": [
        "src/movement/index.d.ts"
      ],
      "presets": [
        "src/presets/index.d.ts"
      ],
      "query": [
        "src/query/index.d.ts"
      ],
      "render2d": [
        "src/render2d/index.d.ts"
      ],
      "render3d": [
        "src/render3d/index.d.ts"
      ],
      "*": [
        "src/index.d.ts"
      ]
    }
  },
  "files": [
    "src",
    "!src/demo",
    "!src/demo/**",
    "!src/**/__tests__",
    "!src/**/__tests__/**",
    "!src/**/*.test.js",
    "!src/**/*.test.mjs",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "diag:observer-shell": "node ./scripts/observer-shell-diagnostic.js",
    "lookup:bookmark-star": "node ./scripts/bookmark-star-lookup.js",
    "test": "node --test",
    "test:watch": "node --test --watch",
    "typecheck:public": "tsc -p ./tsconfig.public.json --noEmit"
  },
  "dependencies": {
    "@found-in-space/touch-os": "^0.2.0-dev.0",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@types/three": "^0.184.0",
    "typescript": "^5.9.3",
    "vite": "^6.0.0"
  }
}
